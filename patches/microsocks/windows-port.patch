+#ifdef _WIN32
+/* Windows (winsock2) build. Must include winsock2.h before windows.h. */
+#include <winsock2.h>
+#include <ws2tcpip.h>
+#include <windows.h>
+#include <stdlib.h>
+#include <string.h>
+#include <stdio.h>
+#include <pthread.h>
+#include <errno.h>
+#include <limits.h>
+/* MinGW-w64 provides getopt via <unistd.h>. */
+#include <unistd.h>
+#include "server.h"
+#include "sblist.h"
+
+/* Map POSIX socket/poll calls to winsock equivalents. On Windows, SOCKETs
+   are distinct from file descriptors, so read/write/close don't work on
+   them directly. These macros are scoped to this translation unit. */
+#define poll(fds, nfds, timeout) WSAPoll((fds), (nfds), (timeout))
+#define close_sock(fd) closesocket(fd)
+#define read(fd, buf, n)  recv((fd), (char*)(buf), (int)(n), 0)
+#define write(fd, buf, n) send((fd), (const char*)(buf), (int)(n), 0)
+
+/* usleep() is sometimes absent from MinGW configurations; provide a
+   Sleep()-based shim that accepts microseconds. */
+static int usleep_ms(unsigned usec) { Sleep((usec + 999) / 1000); return 0; }
+#define usleep(u) usleep_ms(u)
+
+/* dprintf() is POSIX.1-2008 but not exposed by mingw-w64 headers on a
+   default Windows build. Provide a thin vsnprintf + _write shim so the
+   existing dolog()/usage() call sites compile unchanged. */
+#include <stdarg.h>
+#include <io.h>
+static int ms_dprintf(int fd, const char *fmt, ...) {
+	char buf[2048];
+	va_list ap;
+	va_start(ap, fmt);
+	int n = vsnprintf(buf, sizeof buf, fmt, ap);
+	va_end(ap);
+	if(n < 0) return n;
+	if((size_t)n > sizeof buf) n = (int)sizeof buf;
+	return _write(fd, buf, n);
+}
+#define dprintf ms_dprintf
+
+#else  /* !_WIN32: original POSIX includes */
 #define _GNU_SOURCE
 #include <unistd.h>
 #define _POSIX_C_SOURCE 200809L
